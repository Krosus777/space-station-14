<DefaultWindow xmlns="https://spacestation14.io"
              Title="{Loc 'paper-field-picker-title'}"
              MinSize="250 220">
    <BoxContainer Orientation="Vertical" Margin="4">
        <LineEdit Name="Search" HorizontalExpand="True" />
        <ScrollContainer VerticalExpand="True" Margin="0 4 0 4">
            <ItemList Name="Options" SelectMode="Single" HorizontalExpand="True" />
        </ScrollContainer>
        <LineEdit Name="Custom" />
        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Right" Margin="4 4 0 0">
            <Button Name="Confirm" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
